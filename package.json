{
  "name": "accessor-discovery-prototype",
  "displayName": "Accessor Discovery",
  "description": "Completion, hover, and definition support for xarray and pandas accessors in Python.",
  "version": "0.0.1",
  "publisher": "local",
  "preview": true,
  "markdown": "github",
  "repository": {
    "type": "git",
    "url": "https://github.com/karosc/vscode-accessors.git"
  },
  "homepage": "https://github.com/karosc/vscode-accessors#readme",
  "bugs": {
    "url": "https://github.com/karosc/vscode-accessors/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "python",
    "xarray",
    "pandas",
    "accessor",
    "autocomplete",
    "hover",
    "definition",
    "data-science"
  ],
  "galleryBanner": {
    "color": "#12344d",
    "theme": "dark"
  },
  "activationEvents": [
    "onCommand:accessor.analyzeCurrentFile",
    "onLanguage:python"
  ],
  "main": "./extension/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "accessor.analyzeCurrentFile",
        "title": "Accessor: Analyze Current Python File"
      }
    ],
    "configuration": {
      "title": "Accessor Discovery",
      "properties": {
        "accessor.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Optional Python interpreter path used to run the accessor discovery helper. If empty, the extension falls back to Python extension settings and then `python3`."
        }
      }
    }
  },
  "scripts": {
    "test": "npm run test:resolver && npm run test:overlay",
    "test:resolver": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "test:overlay": "node --test tests/*.test.js"
  }
}
