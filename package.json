{
  "name": "accessor-discovery-prototype",
  "displayName": "Accessor Discovery",
  "description": "Completion, hover, and definition support for xarray and pandas accessors in Python.",
  "version": "0.4.0",
  "publisher": "karosc",
  "preview": true,
  "markdown": "github",
  "repository": {
    "type": "git",
    "url": "https://github.com/karosc/vscode-accessors.git"
  },
  "homepage": "https://github.com/karosc/vscode-accessors#readme",
  "bugs": {
    "url": "https://github.com/karosc/vscode-accessors/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "python",
    "xarray",
    "pandas",
    "accessor",
    "autocomplete",
    "hover",
    "definition",
    "data-science"
  ],
  "galleryBanner": {
    "color": "#12344d",
    "theme": "dark"
  },
  "activationEvents": [
    "onCommand:accessor.analyzeCurrentFile",
    "onLanguage:python"
  ],
  "extensionDependencies": [
    "ms-python.python"
  ],
  "main": "./extension.js",
  "dependencies": {
    "@vscode/python-extension": "^1.0.6"
  },
  "contributes": {
    "commands": [
      {
        "command": "accessor.analyzeCurrentFile",
        "title": "Accessor: Analyze Current Python File"
      }
    ],
    "configuration": {
      "title": "Accessor Discovery",
      "properties": {
        "accessor.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Optional Python interpreter path used to run the accessor discovery helper. If set, it overrides the Python extension active environment. If empty, the extension uses the active Python environment from the Python extension."
        }
      }
    }
  },
  "scripts": {
    "test": "npm run test:resolver && npm run test:overlay",
    "test:resolver": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "test:overlay": "node --test tests/*.test.js"
  }
}
